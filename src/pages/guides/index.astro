---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
import { getCollection } from 'astro:content';
import config from '../../data/config.json';

const title = `Guides, Conseils & Actualités de la Borne de Recharge | ${config.brandName}`;
const description = `Retrouvez nos guides techniques, comparatifs de bornes, conseils d'électriciens IRVE et astuces d'installation en Haute-Garonne (31).`;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Guides & Actualités" }
];

// Fetch and sort guides by date (descending)
const allGuides = await getCollection('guides');
const sortedGuides = allGuides.sort((a, b) => 
  new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);
---

<Layout title={title} description={description}>
  <SchemaMarkup 
    slot="head" 
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    breadcrumbItems={breadcrumbItems}
  />

  <Breadcrumb items={breadcrumbItems} />

  <section class="guides-hero-section" style="background: linear-gradient(135deg, #500724 0%, #be185d 100%); color: white; padding: 60px 0; text-align: center; position: relative;">
    <div class="container" style="position: relative; z-index: 2;">
      <h1 class="guides-hero-title" style="font-size: 36px; color: white; margin-bottom: 15px; font-family: var(--font-heading); font-weight: 800;">📚 Guides & Conseils d'Électriciens IRVE</h1>
      <p style="font-size: 16px; color: var(--primary-light); max-width: 700px; margin: 0 auto;">
        Découvrez nos décryptages techniques, comparatifs wallbox 2026, guides d'aides à la transition et astuces d'experts pour vos chantiers de recharge en Haute-Garonne.
      </p>
    </div>
    <div style="position: absolute; top:0; left:0; right:0; bottom:0; background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px); background-size: 20px 20px; pointer-events: none;"></div>
  </section>

  <section style="padding: 60px 0; background-color: var(--bg);">
    <div class="container">
      <div class="guides-listing-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px;">
        {sortedGuides.map((guide) => (
          <article class="guide-list-card" style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-md); overflow: hidden; display: flex; flex-direction: column; box-shadow: var(--shadow-sm); transition: var(--transition);">
            {guide.data.image && (
              <a href={`/guides/${guide.id}/`} style="display: block; aspect-ratio: 16/9; overflow: hidden; background: #111;">
                <img 
                  src={guide.data.image} 
                  alt={guide.data.title} 
                  style="width: 100%; height: 100%; object-fit: cover; transition: var(--transition);" 
                  class="card-img-hover"
                />
              </a>
            )}
            <div style="padding: 24px; display: flex; flex-direction: column; flex-grow: 1; gap: 12px;">
              <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                {guide.data.tags?.map((tag) => (
                  <span style="font-size: 11px; font-weight: 700; background: var(--primary-light); color: var(--primary); padding: 3px 8px; border-radius: 4px; text-transform: uppercase;">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 style="font-size: 18px; line-height: 1.35; margin: 0; font-weight: 700;">
                <a href={`/guides/${guide.id}/`} style="color: var(--primary); text-decoration: none;">
                  {guide.data.title}
                </a>
              </h2>
              <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.5; margin: 0; flex-grow: 1;">
                {guide.data.description}
              </p>
              <div style="border-top: 1px solid var(--primary-light); padding-top: 15px; display: flex; justify-content: space-between; align-items: center; font-size: 12.5px; color: var(--text-muted);">
                <span>📅 {guide.data.publishDate}</span>
                <a href={`/guides/${guide.id}/`} style="color: var(--accent); font-weight: 800; display: inline-flex; align-items: center; gap: 4px;">
                  Lire la suite &rarr;
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .guide-list-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
  }
  .guide-list-card:hover .card-img-hover {
    transform: scale(1.05);
    opacity: 0.9;
  }
  @media (max-width: 992px) {
    .guides-listing-grid {
      grid-template-columns: 1fr 1fr !important;
    }
  }
  @media (max-width: 600px) {
    .guides-listing-grid {
      grid-template-columns: 1fr !important;
    }
    .guides-hero-title {
      font-size: 28px !important;
    }
  }
</style>
