---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import CityMap from '../components/CityMap.astro';
import StepsForm from '../components/StepsForm.astro';
import config from '../data/config.json';
import communes from '../data/communes.json';
import { generateCommuneContent, getDynamicPrices } from '../lib/contentEngine';
import { getSmartNearbyCommunes } from '../lib/geoLinks';

export async function getStaticPaths() {
  return communes.map((c) => ({
    params: { commune: c.slug },
    props: { commune: c },
  }));
}

const { commune } = Astro.props;
const content = generateCommuneContent(commune, 'main');
const prices = getDynamicPrices(commune);

const title = `Installateur Borne de Recharge ${commune.nom} (${commune.codePostal}) | Devis IRVE`;
const description = `Besoin d'un électricien IRVE pour installer votre borne de recharge à ${commune.nom} ? Comparez 3 devis gratuits de Wallbox en Haute-Garonne.`;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes (31)", href: "/communes/" },
  { label: `Installateur ${commune.nom}` }
];

// Get nearby communes for interlinking
const nearby = getSmartNearbyCommunes(commune.slug, communes, 6, 2);
---

<Layout title={title} description={description}>
  <SchemaMarkup 
    slot="head" 
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    breadcrumbItems={breadcrumbItems}
    communeName={commune.nom}
    faqItems={content.faqItems}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Localized Hero Section -->
  <section class="hero" style="background: linear-gradient(135deg, #500724 0%, #be185d 100%); color: white; padding: 60px 0 70px; position: relative;">
    <div class="container">
      <div class="hero-inner" style="display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 40px; align-items: center;">
        <div>
          <span class="hero-badge">⚡ Installateurs Qualifiés IRVE {commune.nom}</span>
          <h1 style="font-size: 36px; color: white; line-height: 1.25; margin-bottom: 20px; font-weight: 800;">
            Installation de Borne de Recharge à {commune.nom} ({commune.codePostal})
          </h1>
          <p style="font-size: 16px; color: var(--primary-light); margin-bottom: 25px; line-height: 1.6;">
            {content.introParagraph}
          </p>
          <div style="display: flex; gap: 15px; flex-wrap: wrap; margin-top: 20px;">
            <div style="background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); padding: 12px 18px; border-radius: 8px; font-size: 13.5px;">
              <strong>Reste à charge estimé :</strong><br/>
              À partir de <span style="color: #fca5a5; font-weight: bold; font-size: 15px;">{prices.wallbox7kW.min - 500} € TTC</span>
            </div>
            <div style="background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); padding: 12px 18px; border-radius: 8px; font-size: 13.5px;">
              <strong>Aides de l'État :</strong><br/>
              Jusqu'à <span style="color: #fca5a5; font-weight: bold; font-size: 15px;">{content.savingsEstimate}</span>
            </div>
          </div>
        </div>
        
        <!-- Interactive Multi-Step Form -->
        <div id="devis">
          <StepsForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Local Page Content & Structure -->
  <section class="static-page-section" style="padding: 65px 0; background-color: var(--bg);">
    <div class="container">
      <div class="two-column-layout">
        
        <!-- Main local content -->
        <div class="static-main-content rich-text" style="background: var(--card-bg); padding: 40px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
          
          <h2>1. {commune.nom} et la mobilité électrique en Haute-Garonne</h2>
          <p>
            {content.densiteAnalysis}
          </p>
          <p>
            {content.localContext}
          </p>

          <blockquote style="border-left: 4px solid var(--accent); background: var(--primary-light); padding: 15px 20px; margin: 25px 0; border-radius: var(--radius-sm); color: var(--primary);">
            <strong>📍 {commune.nom} ({commune.codePostal}) :</strong> {content.distanceLyonContext}
          </blockquote>

          <h2>2. Prix d'installation des bornes de recharge à {commune.nom} (2026)</h2>
          <p>
            {content.tableIntro}
          </p>

          <div class="table-scroll-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Option de recharge</th>
                  <th>Puissance</th>
                  <th>Prix Public Moyen Posé</th>
                  <th>Aides Déduites (Maison)*</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>Prise Renforcée Green'Up</strong></td>
                  <td>3.7 kW (16A)</td>
                  <td class="price">{prices.greenUp.min} € - {prices.greenUp.max} €</td>
                  <td style="font-weight: bold; color: var(--secondary);">{prices.greenUp.min} € - {prices.greenUp.max} €</td>
                </tr>
                <tr>
                  <td><strong>Wallbox Monophasée Standard</strong></td>
                  <td>7.4 kW (32A)</td>
                  <td class="price">{prices.wallbox7kW.min} € - {prices.wallbox7kW.max} €</td>
                  <td style="font-weight: bold; color: var(--secondary);">{prices.wallbox7kW.min - 500} € - {prices.wallbox7kW.max - 500} €</td>
                </tr>
                <tr>
                  <td><strong>Wallbox Triphasée Performante</strong></td>
                  <td>11 / 22 kW</td>
                  <td class="price">{prices.wallbox22kW.min} € - {prices.wallbox22kW.max} €</td>
                  <td style="font-weight: bold; color: var(--secondary);">{prices.wallbox22kW.min - 500} € - {prices.wallbox22kW.max - 500} €</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p style="font-size: 12.5px; color: var(--text-muted); line-height: 1.45;">
            * Les estimations de reste à charge pour {commune.nom} intègrent la réduction d'impôt forfaitaire de 500 € pour les résidents. Pour les copropriétaires raccordés, la prime ADVENIR individuelle vient déduire jusqu'à 960 € TTC complémentaires de la facture.
          </p>

          <h2>3. Contraintes techniques &amp; audit électrique local</h2>
          <p>
            {content.communeDataInsight}
          </p>
          <p>
            {content.logisticsAlert}
          </p>

          <!-- Interactive Map component -->
          <div style="margin: 30px 0; border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
            <CityMap address={`${commune.nom}, Haute-Garonne, France`} />
          </div>

          <h2>4. Impact du raccordement sur votre patrimoine immobilier</h2>
          <p>
            {content.marcheImmobilierInsight}
          </p>
          <p>
            {content.realEstateInsight}
          </p>
          <!-- External Resources & Official Links -->
          <div style="margin-top: 40px; border-top: 1px solid var(--border-color); padding-top: 30px;">
            <h2>5. Ressources officielles et liens utiles</h2>
            <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 15px;">Sources vérifiées et organismes de référence pour votre projet d'installation de borne de recharge à {commune.nom} :</p>
            <div style="display: flex; flex-direction: column; gap: 12px;">
              {content.externalLinks.map((link) => (
                <a href={link.url} target="_blank" rel="noopener noreferrer" style="display: flex; gap: 12px; padding: 14px 18px; background: var(--bg); border: 1px solid var(--border-color); border-radius: var(--radius-sm); transition: var(--transition); align-items: flex-start;">
                  <span style="font-size: 18px; flex-shrink: 0;">🔗</span>
                  <div>
                    <span style="font-weight: 700; font-size: 14px; color: var(--secondary); display: block;">{link.label}</span>
                    <span style="font-size: 12.5px; color: var(--text-muted); line-height: 1.4; display: block; margin-top: 3px;">{link.description}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Guide Links (internal content depth) -->
          <div style="margin-top: 35px; background: var(--primary-light); border: 1.5px solid var(--border-color); padding: 25px; border-radius: var(--radius-md);">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 16px; font-weight: 700; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; margin-bottom: 15px;">📖 Guides complémentaires recommandés</h3>
            <div style="display: flex; flex-direction: column; gap: 12px;">
              {content.guideLinks.map((guide) => (
                <a href={guide.href} style="display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-sm); transition: var(--transition);">
                  <div>
                    <span style="font-weight: 700; font-size: 13.5px; color: var(--secondary);">{guide.label}</span>
                    <span style="font-size: 12px; color: var(--text-muted); display: block; margin-top: 2px;">{guide.desc}</span>
                  </div>
                  <span style="color: var(--accent); font-size: 16px; flex-shrink: 0;">→</span>
                </a>
              ))}
            </div>
          </div>

          <!-- Sources Citation -->
          <p style="font-size: 11.5px; color: var(--text-muted); margin-top: 25px; font-style: italic; border-top: 1px solid var(--border-color); padding-top: 15px;">
            {content.sourcesCitation} — Mis à jour : {content.lastUpdated}
          </p>

          <!-- FAQ Accordion specific to the town -->
          <h2 style="margin-top: 40px;">FAQ : Votre borne de recharge à {commune.nom}</h2>
          <div style="display: flex; flex-direction: column; gap: 14px; margin-top: 20px;">
            {content.faqItems.map((faq) => (
              <details class="faq-details">
                <summary>{faq.question}</summary>
                <div class="faq-answer">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>

          <!-- Interlinking to nearby communes -->
          <div style="border-top: 1px solid var(--border-color); padding-top: 35px; margin-top: 45px;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 16px; margin-bottom: 15px;">📍 Électriciens IRVE dans les communes voisines :</h3>
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;">
              {nearby.map((n) => (
                <a href={`/installateur-borne-recharge-${n.slug}/`} style="font-size: 13px; color: var(--secondary); font-weight: 700; background: var(--primary-light); padding: 8px 12px; border-radius: 4px; border: 1.5px solid var(--border-color);">
                  📍 Pose borne de recharge - {n.nom} ({n.codePostal}) &rarr;
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="static-sidebar">
          <div class="sidebar-widget bg-purple-gradient">
            <h3>🧮 Devis électricien {commune.nom}</h3>
            <p>Remplissez la demande en 2 minutes. Notre réseau local d'artisans haut-garonnais qualifiés vous recontacte pour une étude technique.</p>
            <a href="#devis" class="sidebar-cta-gold">Obtenir mes 3 devis &rarr;</a>
          </div>

          <div class="sidebar-widget">
            <h3>🏢 Solutions alternatives</h3>
            <p style="font-size: 13px;">Vous résidez dans une copropriété ou souhaitez des infos sur l'autoconsommation sous le soleil du Lauragais ?</p>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; font-size: 13px;">
              <li>🏢 <a href={`/borne-recharge-copropriete-${commune.slug}/`} style="color: var(--secondary); font-weight: 700;">Pose en Copropriété à {commune.nom} &rarr;</a></li>
              <li>⚡ <a href={`/wallbox-${commune.slug}/`} style="color: var(--secondary); font-weight: 700;">Modèles Wallbox à {commune.nom} &rarr;</a></li>
            </ul>
          </div>

          <div class="sidebar-widget">
            <h3>💡 Conseil d'expert local</h3>
            <p style="font-size: 13px;">{content.expertTip}</p>
          </div>
        </aside>

      </div>
    </div>
  </section>
</Layout>

<style>
  @media (max-width: 992px) {
    .hero-inner {
      grid-template-columns: 1fr !important;
    }
  }
</style>
